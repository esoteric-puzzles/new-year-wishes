{
  "name": "newyear-wishes",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:stats": "ng build --configuration production --stats-json",
    "analyze": "npx webpack-bundle-analyzer dist/newyear-wishes/browser/stats.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "compress": "node compress-images.js",
    "compress:png": "find src/assets -name '*.png' -exec pngquant --quality=60-80 --ext .png --force {} \\;",
    "compress:jpg": "find src/assets -name '*.jpg' -o -name '*.jpeg' | xargs -I {} jpegoptim --max=80 --strip-all {}",
    "generate:blurhash": "node generate-blurhash.js",
    "convert:webp": "node convert-to-webp.js",
    "optimize:all": "npm run convert:webp && npm run generate:blurhash"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "angular-cli-ghpages": "^2.0.3",
    "blurhash": "^2.0.5",
    "public-google-sheets-parser": "^1.5.4",
    "rxjs": "~7.8.0",
    "seedrandom": "^3.0.5",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.9",
    "@angular/cli": "^17.3.9",
    "@angular/compiler-cli": "^17.3.0",
    "@types/jasmine": "~5.1.0",
    "canvas": "^2.11.2",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.4.2"
  }
}
